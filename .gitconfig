[color]
   ui = true
[color "branch"]
   current = yellow reverse
   local = yellow
   remote = green

[color "diff"]
   meta = yellow bold
   frag = magenta bold
   old = red bold
   new = green bold

[color "status"]
   added = yellow
   changed = green
   untracked = red

[core]
   editor = vim

[init]
   defaultBranch = main

[user]
   name = Joshua Hansen
   email = joshuahansen@outlook.com

[alias]
   ignore = update-index --assume-unchanged
   unignore = update-index --no-assume-unchanged
   ignored = !git ls-files -v | grep "^[[:lower:]]"

[url "git@github.com"]
   insteadOf = gh

