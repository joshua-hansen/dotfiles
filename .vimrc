:set tabstop=3
:set shiftwidth=3
:set expandtab
:set smartindent
:set showmode
:set ruler
:set title
:set scrolloff=4
:set sidescrolloff=4
:set sidescroll=1
:set nowrap
:set number
:set relativenumber
:set cursorline
:set textwidth=80
:set colorcolumn=+1
autocmd FileType gitcommit set textwidth=72
:colorscheme ron

syntax on
let g:markdown_fenced_languages = ['html', 'css', 'js=javascript', 'bash=sh']

